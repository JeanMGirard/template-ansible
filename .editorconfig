root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
max_line_length = 120

[*.py]
indent_size = 4

[{Makefile,*.sh,justfile}]
indent_style = tab
indent_size = 2
end_of_line = lf

[*.{yaml,yml,json,md}]
indent_size = 2
tab_width = 2

[.vault_pass]
end_of_line = lf
insert_final_newline = false
trim_trailing_whitespace = true
